# For Playto team 

# copy paste this into your root .env
# as backend and frontend are deployed on different platforms , it might casue production error, until then try to use playto-engine locally 

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,playto-backend.vercel.app
# Database
DATABASE_URL=postgresql://playto:playto@localhost:5432/playto

# Redis
REDIS_URL=redis://localhost:6379/0
# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://playto-frontend.vercel.app